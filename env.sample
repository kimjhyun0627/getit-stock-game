# ===========================================
# Docker Compose 환경 변수 (로컬·배포 공통)
# 배포 서버: 이 파일을 복사해 .env 로 저장한 뒤 값을 채우고,
#   docker compose up -d --build
# .env 는 Git에 커밋하지 마세요.
# ===========================================

# ---- MySQL ----
MYSQL_ROOT_PASSWORD=stockgame
MYSQL_DATABASE=stockgame
MYSQL_USER=stockgame
MYSQL_PASSWORD=stockgame

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-here-longer-than-32
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---- OAuth (배포 시 실제 값으로 변경) ----
KAKAO_CLIENT_ID=
KAKAO_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- 관리자 권한 부여 (특정 URL에서 비밀번호 입력 시 ADMIN 부여) ----
ADMIN_PASSWORD=

# ---- URL (배포 시 실제 도메인으로 변경) ----
# 로컬: http://localhost
# 배포: https://your-front-domain.com
FRONTEND_URL=http://localhost

# OAuth 콜백은 백엔드 기준 URL (배포 시 예: https://api.your-domain.com/api/auth/kakao/callback)
# docker-compose 기본값이 이미 http://localhost/api/auth/... 이므로 로컬은 수정 불필요
# KAKAO_REDIRECT_URI=http://localhost/api/auth/kakao/callback
# GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback
