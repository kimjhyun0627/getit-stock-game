# ===========================================
# 주식 게임 백엔드 (Spring Boot) 환경 변수 샘플
# 이 파일을 복사하여 .env 로 저장한 뒤 값을 채워주세요.
# .env 는 Git에 커밋하지 마세요.
# ===========================================

# ---- 서버 ----
PORT=3000

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-here
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_EXPIRES_IN=7d

# ---- MySQL (docker 프로필 사용 시) ----
# DB_HOST=localhost
# DB_PORT=3306
# DB_DATABASE=stockgame
# DB_USERNAME=stockgame
# DB_PASSWORD=stockgame

# ---- 카카오 OAuth ----
KAKAO_CLIENT_ID=your-kakao-client-id
KAKAO_CLIENT_SECRET=your-kakao-client-secret
KAKAO_REDIRECT_URI=http://localhost:3000/api/auth/kakao/callback

# ---- 구글 OAuth ----
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# ---- 프론트엔드 URL (CORS, OAuth 리다이렉트) ----
FRONTEND_URL=http://localhost:5173

# ---- Docker 배포 시 예시 ----
# SPRING_PROFILES_ACTIVE=docker
# DB_HOST=mysql
# DB_PORT=3306
# DB_USERNAME=stockgame
# DB_PASSWORD=stockgame
# DB_DATABASE=stockgame
# KAKAO_REDIRECT_URI=http://localhost/api/auth/kakao/callback
# GOOGLE_REDIRECT_URI=http://localhost/api/auth/google/callback
# FRONTEND_URL=http://localhost
